<h1>Banned Books Review App</h1>

<% if (user) { %>

<p>User <%= user.name %> is logged in.</p>

<form method="POST" action="/sessions/logoff" style="display:inline;">
  <input type="hidden" name="_csrf" value="<%= _csrf %>">
  <button type="submit">Logout</button>
</form>

<% } %>

<% if (errors) { %>
  <% errors.forEach((err)=> { %>
  <div style="color:red">
  Error: <%= err %>
  </div>
  <% }) %>
<% } %>

<% if (info) { %>
  <% info.forEach((msg)=> { %>
  <div style="color:green">
  Info: <%= msg %>
  </div>
  <% }) %>
<% } %>

<hr>