<header class="navbar">

  <div class="nav-left">
     <h2>📚 Banned Books Library</h2>
  </div>

  <div class="nav-right">

    <a href="/">Home</a>

<% if (user) { %>

  <a href="/books">My Books</a>

<span class="user-info">Hello, <%= user.name %></span>

<form method="POST" action="/sessions/logoff" style="display:inline;">
  <input type="hidden" name="_csrf" value="<%= _csrf %>">
